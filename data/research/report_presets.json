      "name": "Federal Reserve Selected Interest Rates (H.15)",
      "url": "https://www.federalreserve.gov/releases/h15/"
    },
    "default_chart_type": "yield_dashboard",
    "default_date_start": "1985-01-01",
    "series": [
      { "provider": "fred", "id": "GS10", "alias": "GS10", "title": "10-Year Treasury Constant Maturity" },
      { "provider": "fred", "id": "TB3MS", "alias": "TB3MS", "title": "3-Month Treasury Bill" },
      { "provider": "fred", "id": "T10Y3M", "alias": "T10Y3M", "title": "10Y - 3M Treasury Spread" },
      { "provider": "fred", "id": "T10Y2Y", "alias": "T10Y2Y", "title": "10Y - 2Y Treasury Spread" },
      { "provider": "fred", "id": "USREC", "alias": "USREC", "title": "NBER Recession Indicator" }
    ],
    "formulas": [
      "YC_SPREAD = GS10 - TB3MS",
      "YC_INVERTED = YC_SPREAD < 0"
