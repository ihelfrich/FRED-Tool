[
  {
    "id": "mpr_policy_rates",
    "name": "Monetary Policy Report: Policy Rate Stance",
    "theme": "Policy",
    "description": "Front-end rates and policy stance indicators used to discuss current policy settings.",
    "source": {
      "name": "Federal Reserve Monetary Policy Report",
      "url": "https://www.federalreserve.gov/monetarypolicy/mpr_default.htm"
    },
    "default_chart_type": "line",
    "default_date_start": "2000-01-01",
    "series": [
      { "provider": "fred", "id": "FEDFUNDS", "alias": "FEDFUNDS", "title": "Federal Funds Effective Rate" },
      { "provider": "fred", "id": "SOFR", "alias": "SOFR", "title": "Secured Overnight Financing Rate" },
      { "provider": "fred", "id": "DFF", "alias": "DFF", "title": "Effective Federal Funds Rate (Daily)" },
      { "provider": "fred", "id": "DGS3MO", "alias": "DGS3MO", "title": "3-Month Treasury Yield" },
      { "provider": "fred", "id": "TB3MS", "alias": "TB3MS", "title": "3-Month Treasury Bill" }
    ],
    "formulas": [
      "SOFR_FF_GAP = SOFR - FEDFUNDS",
      "TBILL_FF_GAP = TB3MS - FEDFUNDS"
    ],
    "default_plot_vars": ["FEDFUNDS", "SOFR", "TB3MS", "SOFR_FF_GAP"]
  },
  {
    "id": "yield_curve_recession",
    "name": "Yield Curve Recession Watch",
    "theme": "Policy",
    "description": "Classic term spread monitoring with inversion flags and recession overlay variables.",
